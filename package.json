{
  "name": "shorts-automation",
  "version": "1.0.0",
  "description": "AI-Powered Telegram → CodeOrCap → YouTube Shorts Automation System",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src -e ts --exec ts-node src/index.ts",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "get-token": "ts-node get-refresh-token.ts"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "dotenv": "^16.4.5",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^137.1.0",
    "puppeteer-core": "^25.2.1",
    "sharp": "^0.33.4",
    "telegraf": "^4.16.3",
    "tesseract.js": "^5.1.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.12.12",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
