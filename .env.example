# Telegram Bot Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# YouTube Data API v3 OAuth2 Credentials
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
YOUTUBE_REDIRECT_URI=http://localhost:3000/oauth2callback
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token_here

# AI Provider Settings (options: gemini, claude, antigravity, mock)
# gemini       → Gemini image generation API (free tier, recommended)
# claude       → Claude CLI generates structured JSON → SVG infographic
# antigravity  → agy CLI generates structured JSON → SVG infographic
# mock         → classic SVG+Sharp pipeline, no AI
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
CLAUDE_CLI_PATH=claude
ANTIGRAVITY_CLI_PATH=agy

# Path Configurations (Relative to project root or Absolute paths)
ASSETS_DIR=assets
MUSIC_DIR=assets/music
TEMP_DIR=temp
OUTPUT_DIR=output
LOG_DIR=logs

# Video Rendering Defaults
VIDEO_DURATION_SECONDS=15
VIDEO_FPS=30
MUSIC_VOLUME=0.12
